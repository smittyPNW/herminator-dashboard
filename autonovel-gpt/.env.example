# autonovel-gpt — environment configuration
# Copy to .env and fill in the values.

# ---------------------------------------------------------------------------
# Authentication — choose ONE of the two options below.
# ---------------------------------------------------------------------------

# Option A (RECOMMENDED for Herminator Dashboard users):
#   Paste the OAuth bearer token issued after completing the OpenAI OAuth 2.0
#   PKCE flow in the dashboard.  The token is accepted by the OpenAI API
#   exactly like an API key in the Authorization: Bearer header.
OPENAI_OAUTH_TOKEN=

# Option B (local dev / CI):
#   Standard OpenAI API key from platform.openai.com/api-keys
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Model overrides (optional — defaults shown)
# ---------------------------------------------------------------------------

# Main creative writer (chapter drafting, world-building, characters)
WRITER_MODEL=gpt-4o

# Evaluation and JSON extraction (low temperature tasks)
JUDGE_MODEL=gpt-4o

# Deep review — used by review.py for full-manuscript analysis.
# Set to gpt-4o if you do not have o1 access.
DEEP_MODEL=o1

# Adversarial editing
EDITOR_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Optional base URL override (e.g. Azure OpenAI, local proxy)
# ---------------------------------------------------------------------------
# OPENAI_BASE_URL=https://your-azure-endpoint.openai.azure.com/
