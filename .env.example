DASHBOARD_PASSWORD=change-me
AUTH_SECRET=replace-with-a-long-random-secret
HERMES_DIR=/path/to/.hermes
APP_ORIGIN=http://localhost:3000

# Optional: pin the weather widget to a specific location instead of using
# IP geolocation. Leave unset to auto-detect from your server's IP.
# WEATHER_LAT=45.21
# WEATHER_LON=-123.19
# WEATHER_CITY=My City
# WEATHER_TZ=America/Los_Angeles
